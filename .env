# =============================================================================
# Research Environment — Environment Variables
# =============================================================================
# Copy to .env and adjust as needed.
# Used by docker-compose.yml for image versioning.

# Bitcoin Core version — must be 28.0+ for testnet4 support
BITCOIN_VERSION=28.1

# LND version — 0.18.0+ required for testnet4 support
LND_VERSION=v0.18.3-beta
