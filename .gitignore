# =============================================================================
# Research Environment — .gitignore
# =============================================================================

# ---- Node runtime data (Docker-mounted generated state only) ----------------
# Keep ./data/* directories versionable; ignore only runtime artifacts.
# Runtime *.conf files under data/ are generated/container copies,
# not the canonical configs in ./bitcoin and ./lnd-*/.
data/bitcoin/regtest/
data/**/bitcoin.conf
data/**/lnd.conf

data/alice/data/
data/alice/logs/
data/alice/letsencrypt/

data/bob/data/
data/bob/logs/
data/bob/letsencrypt/

data/carol/data/
data/carol/logs/
data/carol/letsencrypt/

# ---- Secrets & credentials --------------------------------------------------
*.macaroon
data/**/tls.cert
data/**/tls.key
*.key

# ---- Environment variables --------------------------------------------------
#.env
.env.local
.env.*.local

# ---- Logs -------------------------------------------------------------------
*.log

# ---- ThunderHub build output ------------------------------------------------
thunderhub/node_modules/
thunderhub/.next/
thunderhub/dist/

# ---- OS / editor artifacts --------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
