# =============================================================================
# Research Environment — .gitignore
# =============================================================================

# ---- Node runtime data (Docker-mounted generated state only) ----------------
# Keep ./data/* directories versionable; ignore only runtime artifacts.
# Runtime *.conf files under data/ are generated/container copies,
# not the canonical configs in ./bitcoin and ./lnd-*/.
data/bitcoin/regtest/*
!data/bitcoin/.gitkeep
data/**/bitcoin.conf
data/**/lnd.conf

data/alice/*
!data/alice/.gitkeep

data/bob/*
!data/bob/.gitkeep

data/carol/*
!data/carol/.gitkeep

# ---- Secrets & credentials --------------------------------------------------
*.macaroon
data/**/tls.cert
data/**/tls.key
*.key

# ---- Environment variables --------------------------------------------------
#.env
.env.local
.env.*.local

# ---- Logs -------------------------------------------------------------------
*.log

# ---- ThunderHub build output ------------------------------------------------
thunderhub/node_modules/
thunderhub/.next/
thunderhub/dist/

# ---- OS / editor artifacts --------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
